# Azure DB sync — copy to azure.env (gitignored). Do not paste secrets into chat or commit this file.
#   cp scripts/azure.env.example scripts/azure.env
#
# Get storage key (optional if you use `az login` and have RBAC on the share):
#   az storage account keys list --account-name YOUR_ACCOUNT --resource-group YOUR_RG --query "[0].value" -o tsv
#
# Download production DB to Mac:
#   az login
#   ./scripts/db_sync_azure.sh download
#   ./scripts/db_restore_from_backup_snapshot.sh   # pick restore_from_azure.backup

export AZURE_STORAGE_ACCOUNT=stgaccschbuddydev01
export AZURE_STORAGE_KEY="<paste-key-here>"
export AZURE_BACKUP_SHARE=postgres-backup
export AZURE_WEBAPP_NAME=school-buddy
export AZURE_WEBAPP_RG=Schoolbuddy-dev-01
