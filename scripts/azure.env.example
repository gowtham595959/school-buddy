# Azure DB sync — copy to azure.env and add AZURE_STORAGE_KEY
#   cp scripts/azure.env.example scripts/azure.env
#   # Edit azure.env, add the key from command below
#
# Get storage key:
#   az storage account keys list --account-name stgaccschbuddydev01 --resource-group Schoolbuddy-dev-01 --query "[0].value" -o tsv

export AZURE_STORAGE_ACCOUNT=stgaccschbuddydev01
export AZURE_STORAGE_KEY="<paste-key-here>"
export AZURE_BACKUP_SHARE=postgres-backup
export AZURE_WEBAPP_NAME=school-buddy
export AZURE_WEBAPP_RG=Schoolbuddy-dev-01
