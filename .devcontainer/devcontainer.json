{
  "name": "School Buddy Dev",
  "forwardPorts": [3000, 5000],
  "postStartCommand": "if [ -n \"$CODESPACE_NAME\" ] && [ -x /workspaces/school-buddy/scripts/codespace-stop-hourly.sh ]; then (sleep 10; /workspaces/school-buddy/scripts/codespace-stop-hourly.sh &); fi",
  "portsAttributes": {
    "3000": {
      "label": "React Frontend",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "Node Backend",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install",
}
